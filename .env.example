# Meta App Configuration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:8000/auth/meta/callback

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# AI Provider (claude, openai, or grok)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GROK_API_KEY=
GROK_MODEL=grok-3

# Security (generate these with the install script)
SECRET_KEY=generate_64_char_random_string_here
ENCRYPTION_KEY=generate_fernet_key_here

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# App Settings
MAX_UPLOAD_SIZE_MB=100
CACHE_TTL_SECONDS=3600
LOG_LEVEL=INFO
AUTO_CLEAR_UPLOADS_HOURS=24
