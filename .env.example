# Meta Marketing API credentials
# Get these from https://developers.facebook.com/apps/
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Long-lived user access token with ads_management + ads_read permissions
META_ACCESS_TOKEN=your_long_lived_access_token_here

# Your ad account ID — format: act_XXXXXXXXXX
META_AD_ACCOUNT_ID=act_your_account_id_here

# (Optional) Google Drive service account credentials JSON path
# Leave blank to use OAuth flow or skip Drive integration
GOOGLE_SERVICE_ACCOUNT_JSON=

# (Optional) Google OAuth credentials file (from Google Cloud Console)
# Used if GOOGLE_SERVICE_ACCOUNT_JSON is not set
GOOGLE_OAUTH_CREDENTIALS_JSON=
